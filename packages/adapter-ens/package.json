{
  "name": "@openacid/adapter-ens",
  "version": "0.2.1",
  "description": "Mirror @openacid/acid receipts to ENS text records — third parties resolve the audit trail with no library install.",
  "license": "MIT",
  "keywords": [
    "openacid",
    "agent",
    "ai",
    "ens",
    "resolver",
    "text-record",
    "audit-trail"
  ],
  "homepage": "https://github.com/RomarioKavin1/acid",
  "repository": {
    "type": "git",
    "url": "https://github.com/RomarioKavin1/acid.git",
    "directory": "packages/adapter-ens"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@openacid/acid": "workspace:*",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@openacid/acid": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "viem": "^2.21.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
