{
  "name": "@openacid/adapter-memory",
  "version": "0.2.1",
  "description": "In-memory StorageAdapter (atomic cas) and MemorySigner (real secp256k1) for @openacid/acid tests and dry-run agents.",
  "license": "MIT",
  "keywords": [
    "openacid",
    "agent",
    "ai",
    "memory",
    "storage-adapter",
    "signer"
  ],
  "homepage": "https://github.com/RomarioKavin1/acid",
  "repository": {
    "type": "git",
    "url": "https://github.com/RomarioKavin1/acid.git",
    "directory": "packages/adapter-memory"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@openacid/acid": "workspace:*"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@openacid/acid": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
