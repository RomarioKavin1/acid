{
  "name": "@openacid/adapter-0g-storage",
  "version": "0.2.2",
  "description": "Write-through StorageAdapter for @openacid/acid backed by 0G Storage on Galileo testnet — receipts persist as content-addressed blobs.",
  "license": "MIT",
  "keywords": [
    "openacid",
    "agent",
    "ai",
    "0g",
    "0g-storage",
    "galileo",
    "storage-adapter",
    "receipts"
  ],
  "homepage": "https://github.com/RomarioKavin1/acid",
  "repository": {
    "type": "git",
    "url": "https://github.com/RomarioKavin1/acid.git",
    "directory": "packages/adapter-0g-storage"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@openacid/acid": "workspace:*"
  },
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.8",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "@openacid/acid": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
