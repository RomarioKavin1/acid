{
  "name": "@openacid/adapter-0g-storage",
  "version": "0.2.0",
  "description": "0G Storage StorageAdapter for ACID — KV markers + blob receipts.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@openacid/acid": "workspace:*"
  },
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.8",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "@openacid/acid": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
