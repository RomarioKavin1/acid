{
  "name": "@openacid/acid",
  "version": "0.2.1",
  "description": "Durable execution primitives for AI agents that hold real money — atomicity, consistency, isolation, durability as four composable wrappers.",
  "license": "MIT",
  "keywords": [
    "agent",
    "ai",
    "saga",
    "idempotent",
    "invariant",
    "receipt",
    "eip-712",
    "durability",
    "0g",
    "ens"
  ],
  "homepage": "https://github.com/RomarioKavin1/acid",
  "repository": {
    "type": "git",
    "url": "https://github.com/RomarioKavin1/acid.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
