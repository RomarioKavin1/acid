{
  "name": "@openacid/example-uniswap-agent",
  "version": "0.0.0",
  "private": true,
  "description": "Reference agent: ACID-wrapped Uniswap V4 rebalancer on Base Sepolia.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env src/main.ts",
    "dry-run": "tsx --env-file=.env src/main.ts --dry-run",
    "demo:a": "tsx src/demo/atomicity.ts",
    "demo:c": "tsx src/demo/consistency.ts",
    "demo:i": "tsx src/demo/isolation.ts",
    "demo:d": "tsx src/demo/durability.ts",
    "demo:live": "tsx --env-file=.env src/demo/live.ts",
    "demo:all": "tsx src/demo/atomicity.ts && tsx src/demo/consistency.ts && tsx src/demo/isolation.ts && tsx src/demo/durability.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@openacid/acid": "workspace:*",
    "@openacid/adapter-memory": "workspace:*",
    "@openacid/adapter-viem": "workspace:*",
    "@openacid/adapter-0g-storage": "workspace:*",
    "@openacid/adapter-ens": "workspace:*",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
